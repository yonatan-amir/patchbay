# ── macOS notarization (set in CI and local release builds) ──────────────────
# Base64-encoded Developer ID Application .p12 certificate
# Export from Keychain: File → Export Items → .p12 → base64 encode
APPLE_CERTIFICATE=

# Password you chose when exporting the .p12
APPLE_CERTIFICATE_PASSWORD=

# Exact string from Keychain: "Developer ID Application: Your Name (TEAMID)"
APPLE_SIGNING_IDENTITY=

# Your Apple ID email
APPLE_ID=

# App-specific password from appleid.apple.com → Security → App-Specific Passwords
APPLE_PASSWORD=

# 10-char team ID from developer.apple.com → Membership
APPLE_TEAM_ID=

# ── Windows EV code signing ───────────────────────────────────────────────────
# Certificate thumbprint (SHA1) from DigiCert/Sectigo portal after issuance
# In PowerShell: (Get-PfxCertificate -FilePath cert.pfx).Thumbprint
WINDOWS_CERTIFICATE_THUMBPRINT=

# .pfx password (EV certs are usually token-bound; this covers software certs)
WINDOWS_CERTIFICATE_PASSWORD=
